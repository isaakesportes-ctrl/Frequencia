{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "types": ["node"],
    "lib": ["esnext"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": false
  },
  "include": ["server/**/*", "api/**/*", "shared/**/*"]
}